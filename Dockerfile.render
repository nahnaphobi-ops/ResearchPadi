# Render Docker build — context is the repo root.
# All backend paths are prefixed with backend/.
# Uses Debian-based node:22 (not -alpine) so native modules like
# @napi-rs/canvas (pulled in by pdf-parse) get the correct glibc prebuilt binaries.
FROM node:22-bookworm AS builder
WORKDIR /app
COPY backend/package.json ./
RUN npm install --legacy-peer-deps --no-audit --no-fund
COPY backend/ ./
RUN npm run build

FROM node:22-bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends tini \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN addgroup --gid 1001 appgroup && adduser --uid 1001 --ingroup appgroup --disabled-password --gecos "" appuser
COPY --from=builder --chown=appuser:appgroup /app/dist ./dist
COPY --from=builder --chown=appuser:appgroup /app/package.json ./
RUN npm install --legacy-peer-deps --omit=dev --no-audit --no-fund && npm cache clean --force
USER appuser
EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD wget -qO- http://localhost:5000/health/live || exit 1
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "dist/index.js"]
